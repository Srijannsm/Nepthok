// Nepthok — multi-tenant SaaS marketplace
// Phase 2: Full data schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserRole {
  SUPER_ADMIN
  SELLER_ADMIN
  SELLER_STAFF
}

enum PlanTier {
  BASIC
  PRO
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

// Shared across buyer payments (ESEWA, KHALTI, COD)
// and seller subscription payments (ESEWA, KHALTI, BANK_TRANSFER)
enum PaymentMethod {
  ESEWA
  KHALTI
  BANK_TRANSFER
  COD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  logo        String?
  banner      String?
  status      TenantStatus @default(PENDING)

  // "TenantOwner": the SELLER_ADMIN who owns this tenant
  // Named to disambiguate from the "TenantMembers" relation below
  ownerId String
  owner   User   @relation("TenantOwner", fields: [ownerId], references: [id])

  // "TenantMembers": all staff users assigned to this tenant (SELLER_ADMIN + SELLER_STAFF)
  staff User[] @relation("TenantMembers")

  // One-to-one: unique enforced on Subscription.tenantId
  subscription Subscription?

  products        Product[]
  orders          Order[]
  discountCodes   DiscountCode[]
  analytics       StoreAnalytics[]
  contactMessages ContactMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  name     String
  phone    String?
  role     UserRole

  // Nullable: SUPER_ADMIN has no tenant; SELLER_ADMIN/STAFF belongs to one tenant
  // "TenantMembers": matches Tenant.staff back-relation
  tenantId String?
  tenant   Tenant? @relation("TenantMembers", fields: [tenantId], references: [id])

  // "TenantOwner": matches Tenant.owner back-relation
  ownedTenants Tenant[] @relation("TenantOwner")

  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  tier         PlanTier
  price        Decimal      @db.Decimal(10, 2)
  billingCycle BillingCycle

  // null = unlimited (PRO tier); integer cap for BASIC (max 50)
  maxProducts Int?

  features Json
  isActive Boolean @default(true)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id String @id @default(cuid())

  // @unique enforces one active subscription per tenant
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?

  payments SubscriptionPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionPayment {
  id String @id @default(cuid())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  // Denormalized: enables tenant-scoping middleware to filter without joining Subscription
  tenantId String

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("NPR")

  method PaymentMethod
  status PaymentStatus @default(PENDING)

  // Unique: payment gateways return idempotent transaction IDs; prevents double-processing
  transactionId String? @unique

  paidAt   DateTime?
  metadata Json

  createdAt DateTime @default(now())
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  image       String?

  // Self-referential tree — "CategoryTree" disambiguates parent vs children
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  isActive Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name        String
  slug        String
  description String  @db.Text
  price       Decimal @db.Decimal(10, 2)

  // Optional strike-through "was" price for discount display
  comparePrice Decimal? @db.Decimal(10, 2)

  sku     String?
  barcode String?

  stock             Int @default(0)
  lowStockThreshold Int @default(5)

  images     Json
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  status     ProductStatus @default(DRAFT)
  isFeatured Boolean       @default(false)

  // Flexible extra attributes (color, brand, dimensions, etc.)
  metadata Json?

  orderItems       OrderItem[]
  discountProducts DiscountProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Slug is unique within each tenant's namespace
  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Order {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Human-readable, app-generated (e.g. NTK-00001). Used in customer-facing URLs and receipts.
  orderNumber String @unique

  status OrderStatus @default(PENDING)

  // Buyer details captured at order time — guest checkout, no User FK
  buyerName       String
  buyerEmail      String
  buyerPhone      String
  shippingAddress Json

  subtotal    Decimal @db.Decimal(10, 2)
  shippingFee Decimal @db.Decimal(10, 2)
  discount    Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  notes         String?
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  transactionId String?
  paidAt        DateTime?

  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  // Denormalized: enables tenant-scoping middleware to filter without joining Order
  tenantId String

  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Snapshot: preserves order history if product is later edited or archived
  productName String
  productSku  String?

  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)
}

model OrderStatusHistory {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  status OrderStatus
  note   String?

  // Raw string, not a FK — audit trail must survive user account deletion
  changedBy String?

  createdAt DateTime @default(now())
}

model DiscountCode {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  code  String
  type  DiscountType
  value Decimal      @db.Decimal(10, 2)

  minOrderAmount Decimal?  @db.Decimal(10, 2)
  maxUses        Int?
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?

  discountProducts DiscountProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Code is unique within each tenant's namespace
  @@unique([tenantId, code])
}

model DiscountProduct {
  id             String       @id @default(cuid())
  discountCodeId String
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Explicit join table (vs implicit many-to-many) to support @@unique and future extra fields
  @@unique([discountCodeId, productId])
}

model StoreAnalytics {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Application code must normalize to midnight UTC before upsert to respect @@unique below
  date DateTime

  totalOrders       Int     @default(0)
  totalRevenue      Decimal @default(0) @db.Decimal(10, 2)
  totalProductViews Int     @default(0)
  newOrders         Int     @default(0)
  cancelledOrders   Int     @default(0)

  // One record per tenant per calendar day
  @@unique([tenantId, date])
  @@index([tenantId])
}

model ContactMessage {
  id String @id @default(cuid())

  // Nullable: null = platform-level message visible to SUPER_ADMIN only
  // Only model in schema where tenantId is permitted to be null
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  name    String
  email   String
  phone   String?
  message String  @db.Text

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
}
